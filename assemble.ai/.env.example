# ===========================================
# RAG Document Intelligence - Environment Variables
# ===========================================
# Copy this file to .env.local and fill in values

# -----------------------------------------
# Supabase PostgreSQL (for pgvector)
# -----------------------------------------
# Get from: Supabase Dashboard → Project Settings → Database → Connection Pooler
SUPABASE_POSTGRES_URL=postgres://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# -----------------------------------------
# Upstash Redis (for BullMQ)
# -----------------------------------------
# Get from: Upstash Console → Your Database → REST API
UPSTASH_REDIS_URL=redis://default:[password]@[host].upstash.io:6379
UPSTASH_REDIS_TOKEN=your_upstash_redis_token

# -----------------------------------------
# Voyage AI (embeddings)
# -----------------------------------------
# Get from: https://www.voyageai.com/ → Dashboard → API Keys
VOYAGE_API_KEY=your_voyage_api_key

# -----------------------------------------
# LlamaCloud (document parsing - primary)
# -----------------------------------------
# Get from: https://cloud.llamaindex.ai/ → API Keys
LLAMA_CLOUD_API_KEY=your_llama_cloud_api_key

# -----------------------------------------
# Unstructured (document parsing - fallback)
# -----------------------------------------
# Get from: https://unstructured.io/ → API signup
UNSTRUCTURED_API_KEY=your_unstructured_api_key

# -----------------------------------------
# Cohere (reranking - fallback)
# -----------------------------------------
# Get from: https://cohere.com/ → Dashboard → API Keys
COHERE_API_KEY=your_cohere_api_key

# -----------------------------------------
# BAAI Reranker (reranking - primary, optional)
# -----------------------------------------
# Only needed if using hosted BAAI service
# BAAI_API_URL=https://your-baai-endpoint
# BAAI_API_KEY=your_baai_key

# -----------------------------------------
# Anthropic (for AI features including firm data extraction)
# -----------------------------------------
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key

# -----------------------------------------
# OpenAI (optional - enables direct OpenAI models in /admin/models)
# -----------------------------------------
# Required only when a feature group is set to provider "openai".
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# -----------------------------------------
# OpenRouter (optional - enables non-Anthropic models in /admin/models)
# -----------------------------------------
# Required only when a feature group is set to provider "openrouter".
# Get from: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# ===========================================
# POLAR BILLING (SaaS Launch)
# ===========================================

# -----------------------------------------
# Polar API Access Token
# -----------------------------------------
# Get from: https://polar.sh → Settings → API Keys
POLAR_ACCESS_TOKEN=pat_xxx

# -----------------------------------------
# Polar Organization ID
# -----------------------------------------
# Get from: https://polar.sh → Organization Settings
POLAR_ORGANIZATION_ID=org_xxx

# -----------------------------------------
# Polar Webhook Secret
# -----------------------------------------
# Get from: https://polar.sh → Webhooks → Your webhook → Secret
POLAR_WEBHOOK_SECRET=whsec_xxx

# -----------------------------------------
# Polar Product IDs
# -----------------------------------------
# Create products in Polar dashboard, then copy product IDs
POLAR_STARTER_PRODUCT_ID=prod_starter_xxx
POLAR_PROFESSIONAL_PRODUCT_ID=prod_professional_xxx

# ===========================================
# BETTER AUTH
# ===========================================

# -----------------------------------------
# Better Auth Secret
# -----------------------------------------
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=your-better-auth-secret-key-here

# -----------------------------------------
# Better Auth URL (optional, defaults to NEXT_PUBLIC_APP_URL)
# -----------------------------------------
# BETTER_AUTH_URL=http://localhost:3000

# ===========================================
# APPLICATION
# ===========================================

# -----------------------------------------
# Public URL
# -----------------------------------------
# Used for OAuth redirects, Polar webhooks, etc.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# -----------------------------------------
# Session Secret (legacy, used as fallback for BETTER_AUTH_SECRET)
# -----------------------------------------
# Generate a random 32+ character string for signing session tokens
SESSION_SECRET=your-super-secret-session-key-here

# ===========================================
# INNGEST (Reliable Webhook Processing)
# ===========================================

# -----------------------------------------
# Inngest Event Key
# -----------------------------------------
# Get from: https://app.inngest.com → Your App → Events
INNGEST_EVENT_KEY=

# -----------------------------------------
# Inngest Signing Key (Production only)
# -----------------------------------------
# Get from: https://app.inngest.com → Your App → Signing Keys
INNGEST_SIGNING_KEY=

# ===========================================
# SENTRY (Error tracking + performance)
# ===========================================

# -----------------------------------------
# Sentry DSN
# -----------------------------------------
# 1. Sign up free at https://sentry.io  (5,000 errors/month free)
# 2. Create a project → choose "Next.js"
# 3. Copy the DSN it shows you (looks like: https://abc123@o123.ingest.sentry.io/456)
# Leave blank to disable Sentry entirely. Must be NEXT_PUBLIC_ so the browser SDK can use it.
NEXT_PUBLIC_SENTRY_DSN=

# -----------------------------------------
# Sentry source map upload (production builds only)
# -----------------------------------------
# Optional but recommended for production. Without these, prod stack traces show minified code.
# Get auth token from: Sentry → Settings → Auth Tokens (scope: project:releases)
# SENTRY_ORG and SENTRY_PROJECT are shown on your project's settings page.
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
