# Local Development Environment
# This file is safe to commit - contains no secrets

# Local PostgreSQL + Redis via docker-compose
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/assembleai
REDIS_URL=redis://localhost:6379

# Local/private setup should write files under ./uploads unless explicitly configured otherwise
USE_SUPABASE_STORAGE=false

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Local-only placeholders. Put real keys in .env.local when you need AI features.
BETTER_AUTH_SECRET=local-development-better-auth-secret-change-before-production
SESSION_SECRET=local-development-session-secret-change-before-production
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=
VOYAGE_API_KEY=
COHERE_API_KEY=
